generator client {
  provider = "prisma-client-js"
  output   = "./node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserAccount {
  id                 String      @id @default(uuid())
  email              String      @unique
  password           String?
  first_name         String
  join_ip            String
  join_country       String
  admin              Boolean     @default(false)
  created_at         DateTime    @default(now())
  last_name          String
  username           String?     @unique
  verified           Boolean     @default(false)
  email_verified     Boolean     @default(false)
  banned_forever     Boolean     @default(false)
  banned_until       DateTime?
  stripe_customer_id String?     @unique
  is_pro             Boolean     @default(false)
  pro_expires_at     DateTime?
  is_premium         Boolean     @default(false)
  premium_expires_at DateTime?
  revenuecat_user_id   String?   @unique
  iap_platform         String?
  iap_product_id       String?
  iap_original_tx_id   String?
  iap_latest_event_at  DateTime?
  iap_cancellation_at  DateTime?
  iap_billing_issue_at DateTime?
  iap_paused_until     DateTime?
  mod                Boolean     @default(false)
  offline_hash       String?
  unsub_id           String?     @default(uuid())
  last_solve_at              DateTime?
  daily_goal_reminder        Boolean     @default(false)
  last_daily_goal_reminder   DateTime?
  action_log                 ActionLog[]

  algorithm_override            AlgorithmOverride[]
  badges                        Badge[]
  badge_type                    BadgeType[]
  bans                          BanLog[]                @relation("ban_log_banned_user")
  created_bans                  BanLog[]                @relation("ban_log_created_by")
  custom_trainer                CustomTrainer[]
  custom_trainer_downloads      CustomTrainerDownload[] @relation("custom_trainer_download_creator")
  custom_trainer_downloaded     CustomTrainerDownload[] @relation("custom_trainer_download_user")
  custom_trainer_likes          CustomTrainerLike[]     @relation("custom_trainer_like_creator")
  liked_custom_trainers         CustomTrainerLike[]     @relation("custom_trainer_like_user")
  email_log                     EmailLog[]
  forgot_password               ForgotPassword[]
  email_verifications           EmailVerification[]
  image                         Image[]
  integrations                  Integration[]
  metric_logs                   MetricLog[]
  notifications_triggered       Notification[]          @relation("notification_triggering_user")
  notifications                 Notification[]          @relation("notification_for")
  notification_preferences      NotificationPreference?
  profile                       Profile?
  profile_views                 ProfileView[]           @relation("profile_user")
  viewed_profiles               ProfileView[]           @relation("viewer")
  reports_created               Report[]                @relation("report_created_by")
  reports_for                   Report[]                @relation("report_for")
  sessions                      Session[]
  settings                      Setting?
  smart_device                  SmartDevice[]
  solves                        Solve[]
  solve_views                   SolveView[]             @relation("solve_view_user")
  viewed_solve                  SolveView[]             @relation("solve_view_viewer")
  timer_background              TimerBackground?
  top_average                   TopAverage[]
  top_solves                    TopSolve[]
  trainer_favorite              TrainerFavorite[]
  trainer_alternatives          TrainerAlternative[]
  user_feature_state            UserFeatureState?
  wca_records                   WcaRecord[]

  // Friendly Room relations
  friendly_rooms_created        FriendlyRoom[]            @relation("friendly_room_creator")
  friendly_room_participations  FriendlyRoomParticipant[]
  friendly_room_chat_messages   FriendlyRoomChat[]        @relation("friendly_room_chat_user")

  // Announcement relations
  announcementViews             AnnouncementView[]

  // Push notification tokens
  pushTokens                    PushToken[]

  // WCA competition notification tracking (auto-managed dedup state)
  wca_competition_notification_states WcaCompetitionNotificationState[]

  // Daily goals
  daily_goals                   DailyGoal[]

  // Promo codes
  promo_codes_created           PromoCode[]            @relation("promo_code_creator")
  promo_code_redemptions        PromoCodeRedemption[]   @relation("promo_redemption_user")

  // ZKT Unofficial Competitions
  zkt_competitions_created      ZktCompetition[]        @relation("zkt_comp_creator")
  zkt_registrations             ZktRegistration[]       @relation("zkt_registration_user")
  zkt_comp_delegations          ZktCompDelegate[]       @relation("zkt_comp_delegate_user")
  zkt_results                   ZktResult[]             @relation("zkt_result_user")
  zkt_results_entered           ZktResult[]             @relation("zkt_result_entered_by")
  zkt_records                   ZktRecord[]             @relation("zkt_record_holder")
  zkt_assignments               ZktAssignment[]         @relation("zkt_assignment_user")
  zkt_registration_history      ZktRegistrationHistory[] @relation("zkt_registration_history_actor")

  @@map("user_account")
}

model UserFeatureState {
  id                      String      @id @default(uuid())
  user_id                 String      @unique
  received_welcome_screen Boolean     @default(false)
  updated_at              DateTime    @updatedAt
  created_at              DateTime    @default(now())
  user                    UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("user_feature_state")
}

model Integration {
  id              String      @id @default(uuid())
  user_id         String
  service_name    String
  auth_token      String
  refresh_token   String
  auth_expires_at BigInt
  wca_id                 String?     @unique
  wca_country_iso2       String?
  wca_competition_count  Int?
  wca_medal_gold         Int?
  wca_medal_silver       Int?
  wca_medal_bronze       Int?
  wca_record_nr          Int?
  wca_record_cr          Int?
  wca_record_wr          Int?
  wca_show_competitions  Boolean     @default(true)
  wca_show_medals        Boolean     @default(true)
  wca_show_records       Boolean     @default(true)
  wca_show_rank          Boolean     @default(true)
  wca_show_results       Boolean     @default(false)
  kinch_score            Float?
  sor_single             Int?
  sor_average            Int?
  ranks_updated_at       DateTime?
  created_at             DateTime    @default(now())
  user                   UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)
  wca_records            WcaRecord[]

  @@index([user_id])
  @@index([kinch_score])
  @@index([sor_single])
  @@index([sor_average])
  @@map("integration")
}

model Notification {
  id                         String       @id @default(uuid())
  user_id                    String
  notification_type          String
  triggering_user_id         String?
  read_at                    DateTime?
  message                    String
  icon                       String
  link                       String
  created_at                 DateTime     @default(now())
  notification_category_name String
  link_text                  String
  subject                    String
  in_app_message             String?
  triggering_user            UserAccount? @relation("notification_triggering_user", fields: [triggering_user_id], references: [id], onDelete: Cascade)
  user                       UserAccount  @relation("notification_for", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([triggering_user_id])
  @@index([user_id])
  @@map("notification")
}

model ActionLog {
  id             String       @id @default(uuid())
  user_email     String?
  action_type    String
  action_details String?
  created_at     DateTime     @default(now())
  user           UserAccount? @relation(fields: [user_email], references: [email], onDelete: Cascade)

  @@map("action_log")
}

model MetricLog {
  id             String        @id @default(uuid())
  user_email     String?
  metric_type    MetricLogType
  metric_value   Float?
  metric_details String?
  created_at     DateTime      @default(now())
  user           UserAccount?  @relation(fields: [user_email], references: [email], onDelete: SetDefault)

  @@index([metric_type])
  @@index([user_email])
  @@map("metric_log")
}

model NotificationPreference {
  id                    String      @id @default(uuid())
  user_id               String      @unique
  created_at            DateTime    @default(now())
  marketing_emails      Boolean     @default(true)
  membership_granted    Boolean     @default(true)
  user                  UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("notification_preference")
}

model SiteConfig {
  id                   String   @id @default("singleton")
  maintenance_mode     Boolean  @default(false)
  trainer_enabled      Boolean  @default(true)
  community_enabled    Boolean  @default(true)
  leaderboards_enabled Boolean  @default(true)
  rooms_enabled        Boolean  @default(true)
  battle_enabled       Boolean  @default(true)
  pro_enabled          Boolean  @default(false)
  updated_at           DateTime @updatedAt @default(now())
  updated_by           String?

  @@map("site_config")
}

model Profile {
  id                          String        @id @default(uuid())
  user_id                     String        @unique
  header_image_id             String?       @unique
  pfp_image_id                String?       @unique
  created_at                  DateTime      @default(now())
  bio                         String?
  favorite_event              String?
  main_three_cube             String?
  three_goal                  String?
  three_method                String?
  reddit_link                 String?
  twitch_link                 String?
  youtube_link                String?
  twitter_link                String?
  discord_id                  String?
  show_discord_message_button Boolean       @default(true)
  header_image                Image?        @relation("header_image", fields: [header_image_id], references: [id], onDelete: SetDefault)
  pfp_image                   Image?        @relation("pfp_image", fields: [pfp_image_id], references: [id], onDelete: SetDefault)
  user                        UserAccount   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  views                       ProfileView[]

  @@index([user_id])
  @@map("profile")
}

model Image {
  id                   String      @id @default(uuid())
  user_id              String
  url                  String?
  storage_path         String?
  created_at           DateTime    @default(now())
  user                 UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)
  profile_header_image Profile?    @relation("header_image")
  profile_pfp_image    Profile?    @relation("pfp_image")

  @@index([user_id])
  @@map("image")
}

model ProfileView {
  id              String       @id @default(uuid())
  viewer_id       String?
  profile_id      String
  created_at      DateTime     @default(now())
  profile_user_id String
  profile         Profile      @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_user    UserAccount  @relation("profile_user", fields: [profile_user_id], references: [id], onDelete: Cascade)
  viewer          UserAccount? @relation("viewer", fields: [viewer_id], references: [id], onDelete: Cascade)

  @@index([profile_id])
  @@index([profile_user_id])
  @@index([viewer_id])
  @@map("profile_view")
}

model ForgotPassword {
  id         String      @id @default(uuid())
  user_id    String
  code       String
  claimed    Boolean     @default(false)
  created_at DateTime    @default(now())
  user       UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("forgot_password")
}

model EmailVerification {
  id         String      @id @default(uuid())
  user_id    String
  code       String
  claimed    Boolean     @default(false)
  created_at DateTime    @default(now())
  user       UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("email_verification")
}

model Solve {
  id                   String            @id @default(uuid())
  user_id              String
  time                 Float
  raw_time             Float?
  cube_type            String?
  scramble_subset      String?
  scramble             String?
  session_id           String?
  started_at           BigInt?
  ended_at             BigInt?
  dnf                  Boolean           @default(false)
  plus_two             Boolean           @default(false)
  notes                String?
  trainer_name         String?
  created_at           DateTime          @default(now())
  bulk                 Boolean           @default(false)
  inspection_time      Float?            @default(0.0)
  is_smart_cube        Boolean           @default(false)
  smart_put_down_time  Float?            @default(0.0)
  smart_pick_up_time   Float?            @default(0.0)
  smart_turns          String?
  smart_turn_count     Int?
  smart_device_id      String?
  share_code           String?           @unique
  from_timer           Boolean           @default(true)
  custom_scramble      Boolean           @default(false)
  training_session_id  String?
  session              Session?          @relation(fields: [session_id], references: [id], onDelete: Cascade)
  smart_device         SmartDevice?      @relation(fields: [smart_device_id], references: [id], onDelete: SetDefault)
  user                 UserAccount       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  solve_method_steps   SolveMethodStep[]
  solve_views          SolveView[]
  top_average_1        TopAverage[]      @relation("solve_1")
  top_average_2        TopAverage[]      @relation("solve_2")
  top_average_3        TopAverage[]      @relation("solve_3")
  top_average_4        TopAverage[]      @relation("solve_4")
  top_average_5        TopAverage[]      @relation("solve_5")
  top_solve            TopSolve[]

  @@index([created_at])
  @@index([session_id])
  @@index([share_code])
  @@index([bulk])
  @@index([started_at])
  @@index([from_timer])
  @@index([training_session_id])
  @@index([trainer_name])
  @@index([user_id])
  @@index([user_id, created_at])
  @@map("solve")
}

model DemoSolve {
  id              String   @id @default(uuid())
  demo_session_id String
  ip_address      String?
  raw_time        Float?
  cube_type       String?
  scramble        String?
  started_at      BigInt?
  ended_at        BigInt?
  updated_at      DateTime @updatedAt
  created_at      DateTime @default(now())

  @@index([demo_session_id])
  @@index([created_at])
  @@map("demo_solve")
}

model EmailLog {
  id         String       @id @default(uuid())
  user_id    String?
  subject    String
  template   String
  vars       String
  created_at DateTime     @default(now())
  email      String
  user       UserAccount? @relation(fields: [user_id], references: [id], onDelete: SetDefault)

  @@index([user_id])
  @@map("email_log")
}

model SmartDevice {
  id            String      @id @default(uuid())
  name          String
  internal_name String
  created_at    DateTime    @default(now())
  device_id     String
  user_id       String
  user          UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)
  solves        Solve[]

  @@index([user_id])
  @@map("smart_device")
}

model SolveMethodStep {
  id               String   @id @default(uuid())
  solve_id         String
  turn_count       Int
  turns            String?
  method_name      String
  step_index       Int
  step_name        String
  created_at       DateTime @default(now())
  total_time       Float?
  tps              Float?
  parent_name      String?
  recognition_time Float    @default(0.0)
  skipped          Boolean  @default(false)
  oll_case_key     String?
  pll_case_key     String?
  solve            Solve    @relation(fields: [solve_id], references: [id], onDelete: Cascade)

  @@index([solve_id])
  @@map("solve_method_step")
}

model BadgeType {
  id            String       @id @default(uuid())
  name          String
  priority      Int          @default(0)
  color         String
  created_at    DateTime     @default(now())
  description   String
  created_by_id String?
  badges        Badge[]
  created_by    UserAccount? @relation(fields: [created_by_id], references: [id], onDelete: Cascade)

  @@map("badge_type")
}

model Badge {
  id            String      @id @default(uuid())
  user_id       String
  badge_type_id String
  created_at    DateTime    @default(now())
  badge_type    BadgeType   @relation(fields: [badge_type_id], references: [id], onDelete: Cascade)
  user          UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("badge")
}

model TimerBackground {
  id           String      @id @default(uuid())
  url          String?
  storage_path String?
  user_id      String      @unique
  hex          String?
  created_at   DateTime    @default(now())
  user         UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("timer_background")
}

model Report {
  id               String      @id @default(uuid())
  created_at       DateTime    @default(now())
  reason           String?
  created_by_id    String
  reported_user_id String
  resolved_at      DateTime?
  created_by       UserAccount @relation("report_created_by", fields: [created_by_id], references: [id], onDelete: Cascade)
  reported_user    UserAccount @relation("report_for", fields: [reported_user_id], references: [id], onDelete: Cascade)

  @@map("report")
}

model BanLog {
  id             String      @id @default(uuid())
  created_by_id  String
  banned_user_id String
  reason         String
  active         Boolean     @default(true)
  banned_until   DateTime?
  minutes        Int?        @default(-1)
  forever        Boolean     @default(false)
  created_at     DateTime    @default(now())
  banned_user    UserAccount @relation("ban_log_banned_user", fields: [banned_user_id], references: [id], onDelete: Cascade)
  created_by     UserAccount @relation("ban_log_created_by", fields: [created_by_id], references: [id], onDelete: SetDefault)

  @@index([banned_user_id])
  @@map("ban_log")
}

model SolveView {
  id         String       @id @default(uuid())
  solve_id   String
  viewer_id  String?
  user_id    String
  created_at DateTime     @default(now())
  solve      Solve        @relation(fields: [solve_id], references: [id], onDelete: Cascade)
  user       UserAccount  @relation("solve_view_user", fields: [user_id], references: [id], onDelete: Cascade)
  viewer     UserAccount? @relation("solve_view_viewer", fields: [viewer_id], references: [id], onDelete: Cascade)

  @@index([solve_id])
  @@index([user_id])
  @@index([viewer_id])
  @@map("solve_view")
}

model TopSolve {
  id              String      @id @default(uuid())
  user_id         String
  time            Float
  solve_id        String
  cube_type       String
  scramble_subset String?
  created_at      DateTime    @default(now())
  solve      Solve       @relation(fields: [solve_id], references: [id], onDelete: Cascade)
  user       UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([solve_id])
  @@index([time])
  @@index([user_id])
  @@map("top_solve")
}

model TopAverage {
  id              String      @id @default(uuid())
  user_id         String
  time            Float
  cube_type       String
  scramble_subset String?
  solve_1_id String
  solve_2_id String
  solve_3_id String
  solve_4_id String
  solve_5_id String
  created_at DateTime    @default(now())
  solve_1    Solve       @relation("solve_1", fields: [solve_1_id], references: [id], onDelete: Cascade)
  solve_2    Solve       @relation("solve_2", fields: [solve_2_id], references: [id], onDelete: Cascade)
  solve_3    Solve       @relation("solve_3", fields: [solve_3_id], references: [id], onDelete: Cascade)
  solve_4    Solve       @relation("solve_4", fields: [solve_4_id], references: [id], onDelete: Cascade)
  solve_5    Solve       @relation("solve_5", fields: [solve_5_id], references: [id], onDelete: Cascade)
  user       UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([time])
  @@index([user_id])
  @@map("top_average")
}

model Session {
  id         String      @id @default(uuid())
  name       String
  user_id    String
  created_at DateTime    @default(now())
  order      Int         @default(0)
  user       UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)
  solves     Solve[]

  @@index([user_id])
  @@map("session")
}

model CustomTrainer {
  id            String                  @id @default(uuid())
  colors        String?
  cube_type     String
  key           String
  user_id       String
  created_at    DateTime                @default(now())
  name          String
  like_count    Int                     @default(0)
  private       Boolean                 @default(false)
  copy_of_id    String?
  description   String?
  downloaded    Boolean                 @default(false)
  group_name    String?
  scrambles     String?
  solution      String?
  alt_solutions String?
  three_d       Boolean                 @default(false)
  algo_type     String                  @default("Custom")
  copy_of       CustomTrainer?          @relation("copy_of", fields: [copy_of_id], references: [id], onDelete: SetDefault)
  copies        CustomTrainer[]         @relation("copy_of")
  user          UserAccount             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  download_of   CustomTrainerDownload[] @relation("custom_trainer_download_new_trainer")
  downloads     CustomTrainerDownload[] @relation("custom_trainer_download_source_trainer")
  likes         CustomTrainerLike[]

  @@index([user_id])
  @@map("custom_trainer")
}

model CustomTrainerLike {
  id                String        @id @default(uuid())
  custom_trainer_id String
  user_id           String
  created_at        DateTime      @default(now())
  creator_id        String
  creator           UserAccount   @relation("custom_trainer_like_creator", fields: [creator_id], references: [id], onDelete: Cascade)
  custom_trainer    CustomTrainer @relation(fields: [custom_trainer_id], references: [id], onDelete: Cascade)
  user              UserAccount   @relation("custom_trainer_like_user", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([creator_id])
  @@index([custom_trainer_id])
  @@index([user_id])
  @@map("custom_trainer_like")
}

model CustomTrainerDownload {
  id                String         @id @default(uuid())
  user_id           String
  creator_id        String
  created_at        DateTime       @default(now())
  new_trainer_id    String?
  source_trainer_id String
  creator           UserAccount    @relation("custom_trainer_download_creator", fields: [creator_id], references: [id], onDelete: Cascade)
  new_trainer       CustomTrainer? @relation("custom_trainer_download_new_trainer", fields: [new_trainer_id], references: [id], onDelete: Cascade)
  source_trainer    CustomTrainer  @relation("custom_trainer_download_source_trainer", fields: [source_trainer_id], references: [id], onDelete: Cascade)
  user              UserAccount    @relation("custom_trainer_download_user", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([creator_id])
  @@index([new_trainer_id])
  @@index([source_trainer_id])
  @@index([user_id])
  @@map("custom_trainer_download")
}

model TrainerFavorite {
  id         String      @id @default(uuid())
  cube_key   String
  user_id    String
  created_at DateTime    @default(now())
  user       UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("trainer_favorite")
}

model TrainerAlternative {
  id             String      @id @default(uuid())
  category       String
  subset         String
  case_name      String
  algorithm      String
  original_input String
  setup          String?
  ll_pattern     String?
  user_id        String
  created_at     DateTime    @default(now())
  user           UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([category, case_name, algorithm])
  @@index([category, case_name])
  @@index([user_id])
  @@map("trainer_alternative")
}

model AlgorithmOverride {
  id         String      @id @default(uuid())
  user_id    String
  rotate     Int?
  cube_key   String
  created_at DateTime    @default(now())
  solution   String?
  name       String?
  scrambles  String?
  user       UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("algorithm_override")
}

model Setting {
  id                                  String           @id @default(uuid())
  user_id                             String           @unique
  focus_mode                          Boolean          @default(false)
  freeze_time                         Float            @default(0.2)
  inspection                          Boolean          @default(false)
  manual_entry                        Boolean          @default(false)
  inspection_delay                    Int              @default(15)
  inverse_time_list                   Boolean          @default(false)
  hide_time_when_solving              Boolean          @default(false)
  nav_collapsed                       Boolean          @default(false)
  pb_confetti                         Boolean          @default(true)
  play_inspection_sound               Boolean          @default(false)
  zero_out_time_after_solve           Boolean          @default(false)
  confirm_delete_solve                Boolean          @default(false)
  confirm_delete_season               Boolean          @default(false)
  require_period_in_manual_time_entry Boolean          @default(false)
  created_at                          DateTime         @default(now())
  cube_type                           String           @default("333")
  session_id                          String?
  timer_decimal_points                Int              @default(2)
  use_space_with_smart_cube           Boolean          @default(false)
  use_2d_scramble_visual              Boolean          @default(true)
  inspection_auto_start               Boolean          @default(false)
  stats_module_json                   String?
  scramble_subset                     String?
  locale                              String           @default("tr")
  goal_reminder_enabled               Boolean          @default(false)
  custom_cube_types                   CustomCubeType[] @relation("custom_cube_type_setting")
  user                                UserAccount      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("setting")
}

model CustomCubeType {
  id         String   @id @default(uuid())
  user_id    String
  name       String
  created_at DateTime @default(now())
  scramble   String
  private    Boolean  @default(false)
  setting    Setting  @relation("custom_cube_type_setting", fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@map("custom_cube_type")
}

model WcaRecord {
  id                     String      @id @default(uuid())
  user_id                String
  integration_id         String
  wca_event              String // 333, 222, 444, etc.
  single_record          Int? // WCA time in centiseconds
  average_record         Int? // WCA average in centiseconds  
  single_world_rank      Int? // World ranking for single
  average_world_rank     Int? // World ranking for average
  single_continent_rank  Int? // Continental ranking for single
  average_continent_rank Int? // Continental ranking for average
  single_country_rank    Int? // Country ranking for single
  average_country_rank   Int? // Country ranking for average
  published              Boolean     @default(false) // Whether user chose to publish this record
  fetched_at             DateTime    @default(now()) // When this record was last fetched from WCA
  created_at             DateTime    @default(now())
  updated_at             DateTime    @updatedAt
  integration            Integration @relation(fields: [integration_id], references: [id], onDelete: Cascade)
  user                   UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, wca_event])
  @@index([user_id])
  @@index([integration_id])
  @@index([published])
  @@map("wca_record")
}

model WorldRecord {
  id                String   @id @default(uuid())
  event_id          String   @unique
  single_best       Int?
  single_person_id  String?
  single_person_name String?
  average_best      Int?
  average_person_id String?
  average_person_name String?
  last_synced_at    DateTime @default(now())
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("world_record")
}

enum MetricLogType {
  DELETE_USER_ACCOUNT
}

// ==========================================
// FRIENDLY ROOMS - Dostluk Odaları Sistemi
// ==========================================

enum FriendlyRoomStatus {
  WAITING
  ACTIVE
  CLOSED
}

model FriendlyRoom {
  id               String                    @id @default(uuid())
  name             String
  password         String?
  cube_type        String                    @default("333")
  max_players      Int                       @default(8)
  created_by_id    String
  is_private       Boolean                   @default(false)
  allowed_timer_types String[]               @default(["keyboard", "stackmat", "smart", "gantimer", "manual"])
  original_creator_id String?
  current_scramble String?
  scramble_subset  String?
  scramble_index   Int                       @default(0)
  status           FriendlyRoomStatus        @default(WAITING)
  created_at       DateTime                  @default(now())
  updated_at       DateTime                  @updatedAt

  created_by       UserAccount               @relation("friendly_room_creator", fields: [created_by_id], references: [id], onDelete: Cascade)
  participants     FriendlyRoomParticipant[]
  solves           FriendlyRoomSolve[]
  chat_messages    FriendlyRoomChat[]

  @@index([created_by_id])
  @@index([status])
  @@map("friendly_room")
}

model FriendlyRoomParticipant {
  id           String              @id @default(uuid())
  room_id      String
  user_id      String
  is_ready     Boolean             @default(false)
  is_spectator Boolean             @default(false)
  joined_at    DateTime            @default(now())

  room      FriendlyRoom        @relation(fields: [room_id], references: [id], onDelete: Cascade)
  user      UserAccount         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  solves    FriendlyRoomSolve[]

  @@unique([room_id, user_id])
  @@index([room_id])
  @@index([user_id])
  @@map("friendly_room_participant")
}

model FriendlyRoomSolve {
  id             String                  @id @default(uuid())
  room_id        String
  participant_id String
  scramble_index Int
  time           Float
  dnf            Boolean                 @default(false)
  plus_two       Boolean                 @default(false)
  created_at     DateTime                @default(now())

  room           FriendlyRoom            @relation(fields: [room_id], references: [id], onDelete: Cascade)
  participant    FriendlyRoomParticipant @relation(fields: [participant_id], references: [id], onDelete: Cascade)

  @@index([room_id])
  @@index([participant_id])
  @@index([scramble_index])
  @@map("friendly_room_solve")
}

model FriendlyRoomChat {
  id         String       @id @default(uuid())
  room_id    String
  user_id    String
  message    String
  created_at DateTime     @default(now())

  room       FriendlyRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)
  user       UserAccount  @relation("friendly_room_chat_user", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([room_id])
  @@index([user_id])
  @@map("friendly_room_chat")
}

model FriendlyRoomBan {
  id         String       @id @default(uuid())
  room_id    String
  user_id    String
  banned_at  DateTime     @default(now())

  @@unique([room_id, user_id])
  @@index([room_id])
  @@index([user_id])
  @@map("friendly_room_ban")
}

// ==========================================
// ANNOUNCEMENTS - Duyuru Sistemi
// ==========================================

enum AnnouncementCategory {
  FEATURE    // Yenilik
  BUGFIX     // Düzeltme
  IMPORTANT  // Önemli
  INFO       // Bilgilendirme

  @@map("announcement_category")
}

model Announcement {
  id          String                @id @default(uuid())
  title       String
  content     String                @db.Text  // Markdown content
  category    AnnouncementCategory  @default(INFO)
  priority    Int                   @default(0)  // Yüksek = daha önemli (0-10)
  imageUrl    String?               @map("image_url")  // Opsiyonel header resmi
  isDraft     Boolean               @default(false) @map("is_draft")  // Taslak mı?
  createdAt   DateTime              @default(now()) @map("created_at")
  publishedAt DateTime?             @map("published_at")  // Yayınlanma tarihi
  isActive    Boolean               @default(true) @map("is_active")
  translations Json?                               // {"en": {"title":"...","content":"..."}, "es": {...}, "ru": {...}}

  views AnnouncementView[]

  @@index([isActive])
  @@index([isDraft])
  @@index([publishedAt])
  @@map("announcements")
}

model AnnouncementView {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  announcementId String       @map("announcement_id")
  viewedAt       DateTime     @default(now()) @map("viewed_at")

  user         UserAccount  @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
  @@index([userId])
  @@index([announcementId])
  @@map("announcement_views")
}

// ==========================================
// PUSH NOTIFICATIONS - Bildirim Token'lari
// ==========================================

enum PushTokenPlatform {
  WEB
  ANDROID
  IOS

  @@map("push_token_platform")
}

model DailyGoal {
  id              String      @id @default(uuid())
  user_id         String
  cube_type       String
  scramble_subset String      @default("")
  target          Int
  enabled         Boolean     @default(true)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  user            UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, cube_type, scramble_subset])
  @@index([user_id])
  @@map("daily_goal")
}

model PushToken {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  token     String             @unique
  platform  PushTokenPlatform  @default(WEB)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model WcaCompetitionNotificationState {
  id             String   @id @default(uuid())
  user_id        String
  competition_id String
  start_date     DateTime @db.Date
  end_date       DateTime @db.Date
  wca_id         String
  person_name    String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user            UserAccount                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notified_rounds WcaCompetitionNotifiedRound[]

  @@unique([user_id, competition_id])
  @@index([competition_id, end_date])
  @@index([end_date])
  @@map("wca_competition_notification_state")
}

model WcaCompetitionNotifiedRound {
  id              String   @id @default(uuid())
  state_id        String
  activity_code   String
  result_notified Boolean  @default(false)
  finish_notified Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  state WcaCompetitionNotificationState @relation(fields: [state_id], references: [id], onDelete: Cascade)

  @@unique([state_id, activity_code])
  @@map("wca_competition_notified_round")
}

model PromoCode {
  id               String               @id @default(uuid())
  code             String               @unique
  membership_type  String
  duration_minutes Int
  max_uses         Int                  @default(1)
  current_uses     Int                  @default(0)
  is_active        Boolean              @default(true)
  expires_at       DateTime?
  created_at       DateTime             @default(now())
  created_by_id    String
  created_by       UserAccount          @relation("promo_code_creator", fields: [created_by_id], references: [id], onDelete: Cascade)
  redemptions      PromoCodeRedemption[]

  @@index([code])
  @@map("promo_code")
}

model PromoCodeRedemption {
  id            String      @id @default(uuid())
  promo_code_id String
  user_id       String
  redeemed_at   DateTime    @default(now())
  promo_code    PromoCode   @relation(fields: [promo_code_id], references: [id], onDelete: Cascade)
  user          UserAccount @relation("promo_redemption_user", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([promo_code_id, user_id])
  @@index([user_id])
  @@map("promo_code_redemption")
}

// ============================================================================
// ZKT UNOFFICIAL COMPETITION PLATFORM (Zeka Küpü Türkiye)
// ============================================================================

enum ZktCompStatus {
  DRAFT
  CONFIRMED
  ANNOUNCED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  ONGOING
  FINISHED
  PUBLISHED
  CANCELLED

  @@map("zkt_comp_status")
}

enum ZktCompVisibility {
  PUBLIC
  PRIVATE

  @@map("zkt_comp_visibility")
}

enum ZktChampionshipType {
  NATIONAL
  REGIONAL
  CITY
  INVITATIONAL
  YOUTH

  @@map("zkt_championship_type")
}

enum ZktRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  WITHDRAWN

  @@map("zkt_registration_status")
}

enum ZktRoundFormat {
  BO1
  BO2
  BO3
  MO3
  AO5

  @@map("zkt_round_format")
}

enum ZktRoundStatus {
  UPCOMING
  OPEN
  ACTIVE
  FINISHED

  @@map("zkt_round_status")
}

enum ZktAdvancementType {
  RANKING
  PERCENT

  @@map("zkt_advancement_type")
}

model ZktCompetition {
  id                         String             @id @default(uuid())
  name                       String
  description                String?            @db.Text
  date_start                 DateTime           @db.Date
  date_end                   DateTime           @db.Date
  location                   String
  location_address           String?
  competitor_limit           Int?
  status                     ZktCompStatus      @default(DRAFT)
  visibility                 ZktCompVisibility  @default(PUBLIC)
  championship_type          ZktChampionshipType?
  confirmed_at               DateTime?
  announced_at               DateTime?
  announced_by_id            String?
  cancelled_at               DateTime?
  cancel_reason              String?
  results_published_at       DateTime?
  registration_edit_deadline DateTime?
  created_by_id              String
  created_at                 DateTime           @default(now())
  updated_at                 DateTime           @updatedAt

  created_by       UserAccount        @relation("zkt_comp_creator", fields: [created_by_id], references: [id], onDelete: Cascade)
  events           ZktCompEvent[]
  registrations    ZktRegistration[]
  delegates        ZktCompDelegate[]

  @@index([status])
  @@index([created_by_id])
  @@index([date_start])
  @@map("zkt_competition")
}

model ZktCompEvent {
  id             String         @id @default(uuid())
  competition_id String
  event_id       String
  event_order    Int            @default(0)
  created_at     DateTime       @default(now())

  competition    ZktCompetition @relation(fields: [competition_id], references: [id], onDelete: Cascade)
  rounds         ZktRound[]

  @@unique([competition_id, event_id])
  @@index([competition_id])
  @@map("zkt_comp_event")
}

model ZktRound {
  id                String              @id @default(uuid())
  comp_event_id     String
  round_number      Int
  format            ZktRoundFormat      @default(AO5)
  time_limit_cs     Int?
  cutoff_cs         Int?
  cutoff_attempts   Int?
  advancement_type  ZktAdvancementType?
  advancement_level Int?
  status            ZktRoundStatus      @default(UPCOMING)
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt

  comp_event        ZktCompEvent        @relation(fields: [comp_event_id], references: [id], onDelete: Cascade)
  results           ZktResult[]
  groups            ZktGroup[]
  assignments       ZktAssignment[]
  scrambles         ZktScramble[]

  @@unique([comp_event_id, round_number])
  @@index([comp_event_id])
  @@index([status])
  @@map("zkt_round")
}

model ZktScramble {
  id              String   @id @default(uuid())
  round_id        String
  attempt_number  Int      // 1-5 regular, 6+ extra
  is_extra        Boolean  @default(false)
  scramble_string String   @db.Text
  created_at      DateTime @default(now())

  round           ZktRound @relation(fields: [round_id], references: [id], onDelete: Cascade)

  @@unique([round_id, attempt_number])
  @@index([round_id])
  @@map("zkt_scramble")
}

model ZktGroup {
  id           String          @id @default(uuid())
  round_id     String
  group_number Int
  start_time   DateTime?
  end_time     DateTime?
  created_at   DateTime        @default(now())

  round        ZktRound        @relation(fields: [round_id], references: [id], onDelete: Cascade)
  assignments  ZktAssignment[]

  @@unique([round_id, group_number])
  @@index([round_id])
  @@map("zkt_group")
}

model ZktRegistration {
  id                    String                 @id @default(uuid())
  competition_id        String
  user_id               String
  status                ZktRegistrationStatus  @default(PENDING)
  notes                 String?
  admin_comment         String?
  guests                Int                    @default(0)
  waiting_list_position Int?
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt

  competition    ZktCompetition            @relation(fields: [competition_id], references: [id], onDelete: Cascade)
  user           UserAccount               @relation("zkt_registration_user", fields: [user_id], references: [id], onDelete: Cascade)
  events         ZktRegistrationEvent[]
  history        ZktRegistrationHistory[]

  @@unique([competition_id, user_id])
  @@index([competition_id])
  @@index([user_id])
  @@index([status])
  @@index([competition_id, waiting_list_position])
  @@map("zkt_registration")
}

model ZktRegistrationHistory {
  id                  String          @id @default(uuid())
  registration_id     String
  actor_id            String
  action              String
  changed_attributes  Json?
  created_at          DateTime        @default(now())

  registration        ZktRegistration @relation(fields: [registration_id], references: [id], onDelete: Cascade)
  actor               UserAccount     @relation("zkt_registration_history_actor", fields: [actor_id], references: [id], onDelete: Cascade)

  @@index([registration_id])
  @@index([actor_id])
  @@map("zkt_registration_history")
}

model ZktRegistrationEvent {
  id              String          @id @default(uuid())
  registration_id String
  comp_event_id   String
  created_at      DateTime        @default(now())

  registration    ZktRegistration @relation(fields: [registration_id], references: [id], onDelete: Cascade)

  @@unique([registration_id, comp_event_id])
  @@index([registration_id])
  @@map("zkt_registration_event")
}

model ZktCompDelegate {
  id             String         @id @default(uuid())
  competition_id String
  user_id        String
  created_at     DateTime       @default(now())

  competition    ZktCompetition @relation(fields: [competition_id], references: [id], onDelete: Cascade)
  user           UserAccount    @relation("zkt_comp_delegate_user", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([competition_id, user_id])
  @@index([competition_id])
  @@index([user_id])
  @@map("zkt_comp_delegate")
}

model ZktResult {
  id                  String      @id @default(uuid())
  round_id            String
  user_id             String
  attempt_1           Int?
  attempt_2           Int?
  attempt_3           Int?
  attempt_4           Int?
  attempt_5           Int?
  best                Int?
  average             Int?
  ranking             Int?
  proceeds            Boolean     @default(false)
  no_show             Boolean     @default(false)
  single_record_tag   String?
  average_record_tag  String?
  entered_by_id       String
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt

  round               ZktRound    @relation(fields: [round_id], references: [id], onDelete: Cascade)
  user                UserAccount @relation("zkt_result_user", fields: [user_id], references: [id], onDelete: Cascade)
  entered_by          UserAccount @relation("zkt_result_entered_by", fields: [entered_by_id], references: [id], onDelete: Cascade)

  @@unique([round_id, user_id])
  @@index([round_id])
  @@index([user_id])
  @@index([ranking])
  @@map("zkt_result")
}

model ZktRecord {
  id             String      @id @default(uuid())
  event_id       String
  record_type    String
  value          Int
  user_id        String
  result_id      String
  competition_id String
  set_at         DateTime    @default(now())
  created_at     DateTime    @default(now())

  user           UserAccount @relation("zkt_record_holder", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([event_id, record_type])
  @@index([user_id])
  @@map("zkt_record")
}

enum ZktAssignmentRole {
  COMPETITOR
  JUDGE
  SCRAMBLER
  RUNNER
  ORGANIZER
  STAFF

  @@map("zkt_assignment_role")
}

model ZktAssignment {
  id             String            @id @default(uuid())
  round_id       String
  group_id       String?
  user_id        String
  role           ZktAssignmentRole
  station_number Int?
  seed_result    Int?
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  round          ZktRound          @relation(fields: [round_id], references: [id], onDelete: Cascade)
  group          ZktGroup?         @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user           UserAccount       @relation("zkt_assignment_user", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([round_id, user_id, role])
  @@index([round_id, role])
  @@index([group_id, role])
  @@index([user_id])
  @@map("zkt_assignment")
}

