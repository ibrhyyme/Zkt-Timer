default_platform(:ios)

TEAM_ID = "R6CCJB68TQ"
APP_IDENTIFIER = "com.zktimer.app"
ASC_APP_ID = "11492926306"

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: File.expand_path("~/fastlane_api_key.p8"),
      duration: 1200,
      in_house: false
    )

    cocoapods(podfile: "./Podfile")

    if ENV["SKIP_FASTLANE_CERT"] != "true"
      cert(
        team_id: TEAM_ID,
        api_key: api_key,
        keychain_path: ENV["FASTLANE_KEYCHAIN_PATH"],
        keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"],
        output_path: "./fastlane/certs"
      )
    else
      UI.message("Using pre-imported distribution certificate from keychain - skipping cert action")
    end

    sigh(
      app_identifier: APP_IDENTIFIER,
      team_id: TEAM_ID,
      api_key: api_key,
      force: true
    )

    latest_build = latest_testflight_build_number(
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      initial_build_number: 0
    )

    latest_version_str = lane_context[SharedValues::LATEST_TESTFLIGHT_VERSION] || "2.0.0"
    version_parts = latest_version_str.split(".")
    version_parts[-1] = (version_parts[-1].to_i + 1).to_s
    next_version = version_parts.join(".")
    UI.message("Bumping version: #{latest_version_str} -> #{next_version}")

    increment_version_number(
      xcodeproj: "App.xcodeproj",
      version_number: next_version
    )
    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: latest_build + 1
    )

    profile_name = ENV["SIGH_NAME"]
    profile_uuid = ENV["SIGH_UUID"]

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      clean: true,
      codesigning_identity: "Apple Distribution",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name
        }
      },
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY=\"Apple Distribution\" PROVISIONING_PROFILE_SPECIFIER=\"#{profile_name}\" PROVISIONING_PROFILE=\"#{profile_uuid}\""
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
