default_platform(:ios)

TEAM_ID = "R6CCJB68TQ"
APP_IDENTIFIER = "com.zktimer.app"
APPLE_ID = "ibrhyyme@icloud.com"
ASC_APP_ID = "11492926306"
API_KEY_ID = "278D2L3BH8"
API_ISSUER_ID = "15c07082-4443-4431-8d56-a7ac72f92933"
API_KEY_PATH = File.expand_path("~/fastlane_api_key.p8")

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: API_KEY_ID,
      issuer_id: API_ISSUER_ID,
      key_filepath: API_KEY_PATH,
      duration: 1200,
      in_house: false
    )

    cocoapods(podfile: "./Podfile")

    cert(
      team_id: TEAM_ID,
      username: APPLE_ID
    )

    sigh(
      app_identifier: APP_IDENTIFIER,
      team_id: TEAM_ID,
      username: APPLE_ID,
      force: true
    )

    latest_build = latest_testflight_build_number(
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      initial_build_number: 0
    )
    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: latest_build + 1
    )

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      clean: true,
      codesigning_identity: "Apple Distribution",
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY=\"Apple Distribution\" PROVISIONING_PROFILE_SPECIFIER=\"com.zktimer.app AppStore\""
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
