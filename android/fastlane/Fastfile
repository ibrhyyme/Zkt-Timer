default_platform(:android)

PACKAGE_NAME = "com.zktimer.app"

platform :android do
  desc "Build and upload to Play Store Internal Track"
  lane :beta do
    json_key_path = ENV["PLAY_STORE_JSON_KEY_PATH"]

    # Auto-bump versionCode without touching build.gradle (was manual → easy to
    # forget → "duplicate versionCode" rejection). Derived from the CI run number
    # (monotonic, well above any existing Play code) and passed as the custom
    # -PciVersionCode gradle property, which build.gradle reads in defaultConfig.
    # NOT android.injected.version.code: modern AGP silently ignores it (proven
    # 2026-07-13: AAB shipped with the static versionCode and Play rejected it).
    # Deliberately NOT google_play_track_version_codes (nil flat_map bug on this
    # fastlane) and NOT a property literally named versionCode (clashes with the
    # gradle DSL keyword) — see the github-actions-deploy skill for these traps.
    next_version_code = 1000 + (ENV["GITHUB_RUN_NUMBER"] || "0").to_i
    UI.message("Bumping versionCode -> #{next_version_code}")

    gradle(
      task: "clean bundleRelease",
      project_dir: ".",
      properties: {
        "ciVersionCode" => next_version_code,
        "android.injected.signing.store.file" => ENV["ANDROID_KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias" => ENV["ANDROID_KEY_ALIAS"],
        "android.injected.signing.key.password" => ENV["ANDROID_KEY_PASSWORD"]
      }
    )

    upload_to_play_store(
      track: "internal",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      json_key: json_key_path,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end
end
